# ── 数据目录（可选，默认 ./runtime）────────────────────
# WHOGA_RUNTIME_DIR=./runtime
# QUERY_STATS_DIR=./runtime

# ── 数据自动刷新安全（生产环境建议设置）────────────────
# 设置后，/api/admin/refresh 需要 Authorization: Bearer <secret>
CRON_SECRET=

# ── 缓存 ────────────────────────────────────────────────
REDIS_URL=
WHOIS_CACHE_TTL_SECONDS=900

# ── 可选：额外 RDAP 映射源 ──────────────────────────────
# RDAP_EXTRA_SOURCE_URL=
# GEO_TLDS_SOURCE_URL=

# ── 可选：Cloudflare（仅部分运维脚本需要）──────────────
CLOUDFLARE_EMAIL=
CLOUDFLARE_API_KEY=
FLAGCDN_ZONE_ID=
